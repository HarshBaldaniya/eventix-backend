{
  "openapi": "3.0.3",
  "info": {
    "title": "Eventix API",
    "description": "Eventix Event Booking System — REST API for event management, ticket booking, and audit logging.\n\n## Authentication\n- **JWT Bearer:** Most endpoints require `Authorization: Bearer <access_token>` from login/register.\n- **Public:** Health, list events (published/coming_soon), get event by ID.\n- **Admin only:** Create/update events, list audit log.\n\n## Rate Limiting\n- Default: 100 requests per minute per IP (configurable via `API_RATE_LIMIT_*`).\n- 429 response when exceeded.\n\n## Error Format\nAll errors return `{ success: false, error: { code, message, details } }`.",
    "version": "1.2.0",
    "contact": {
      "name": "Eventix API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "tags": [
    { "name": "Eventix API / Health", "description": "API and database health checks" },
    { "name": "Eventix API / Auth", "description": "Registration, login, logout, token refresh" },
    { "name": "Eventix API / Events", "description": "Event listing, creation, updates" },
    { "name": "Eventix API / Bookings", "description": "Book spots, list, cancel bookings" },
    { "name": "Eventix API / Audit Log", "description": "View audit log entries" }
  ],
  "x-tagGroups": [
    {
      "name": "Eventix API",
      "tags": [
        "Eventix API / Health",
        "Eventix API / Auth",
        "Eventix API / Events",
        "Eventix API / Bookings",
        "Eventix API / Audit Log"
      ]
    }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": ["Eventix API / Health"],
        "summary": "Health Check",
        "description": "Returns API and PostgreSQL connectivity status. Use for load balancer health checks, monitoring, and startup probes. No authentication required.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service healthy. DB connected.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "db": { "type": "string", "example": "connected" }
                  }
                },
                "example": {
                  "status": "ok",
                  "db": "connected"
                }
              }
            }
          },
          "503": {
            "description": "Service unhealthy. Database unreachable.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "error": {
                    "code": "EVB503001",
                    "message": "Database unavailable",
                    "details": null
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": ["Eventix API / Auth"],
        "summary": "Register",
        "description": "Register a new user. Returns access and refresh tokens. Creates a session for logout/refresh. Role is always `user` (admin cannot self-register). Password must be at least 8 characters.",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "user@example.com" },
                  "password": { "type": "string", "minLength": 8, "example": "SecureP@ss123" },
                  "name": { "type": "string", "example": "John Doe" },
                  "role": { "type": "string", "enum": ["user"], "default": "user", "example": "user" }
                }
              },
              "example": {
                "email": "user@example.com",
                "password": "SecureP@ss123",
                "name": "John Doe"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": { "$ref": "#/components/schemas/AuthResponse" }
                  }
                },
                "example": {
                  "success": true,
                  "data": {
                    "user": { "id": 1, "email": "user@example.com", "name": "John Doe" },
                    "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                    "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                    "expires_in": 3600
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "error": {
                    "code": "EVB400001",
                    "message": "Validation failed",
                    "details": { "email": "Invalid email format", "password": "Password must be at least 8 characters" }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "success": false, "error": { "code": "EVB429001", "message": "Too many requests", "details": null } }
              }
            }
          },
          "409": {
            "description": "Email already registered",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "error": {
                    "code": "EVB409003",
                    "message": "Email already registered",
                    "details": { "email": "user@example.com" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["Eventix API / Auth"],
        "summary": "Login",
        "description": "Authenticate with email and password. Returns access token (short-lived) and refresh token (long-lived). Creates a session for logout/refresh. Invalid credentials return 401.",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "user@example.com" },
                  "password": { "type": "string", "example": "SecureP@ss123" }
                }
              },
              "example": {
                "email": "user@example.com",
                "password": "SecureP@ss123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": { "$ref": "#/components/schemas/AuthResponse" }
                  }
                },
                "example": {
                  "success": true,
                  "data": {
                    "user": { "id": 1, "email": "user@example.com", "name": "John Doe" },
                    "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                    "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                    "expires_in": 3600
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "error": {
                    "code": "EVB401001",
                    "message": "Invalid email or password",
                    "details": null
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "success": false, "error": { "code": "EVB429001", "message": "Too many requests", "details": null } }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": ["Eventix API / Auth"],
        "summary": "Logout",
        "description": "Invalidate the session by sending the refresh token. Marks the session as inactive (soft delete). Does not require Bearer token.",
        "operationId": "logout",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refresh_token"],
                "properties": {
                  "refresh_token": { "type": "string", "description": "JWT refresh token to invalidate" }
                }
              },
              "example": {
                "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logged out successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "type": "object",
                      "properties": { "message": { "type": "string", "example": "Logged out" } }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/refresh": {
      "post": {
        "tags": ["Eventix API / Auth"],
        "summary": "Refresh Token",
        "description": "Exchange a valid refresh token for new access and refresh tokens. Session must be active and not expired. Use when access token expires.",
        "operationId": "refresh",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refresh_token"],
                "properties": {
                  "refresh_token": { "type": "string" }
                }
              },
              "example": {
                "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tokens refreshed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": { "$ref": "#/components/schemas/AuthResponse" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired refresh token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "error": {
                    "code": "EVB401001",
                    "message": "Session expired or invalid",
                    "details": null
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/events": {
      "get": {
        "tags": ["Eventix API / Events"],
        "summary": "List Events",
        "description": "List events with pagination and filters. **Public (no auth):** returns only `published` and `coming_soon`. **Admin (Bearer token):** returns all statuses including `draft`, `cancelled`, `completed`. Search matches name and description. Sort by created_at, name, or remaining_spots.",
        "operationId": "listEvents",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 1 }, "description": "Page number (1-based)" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 10 }, "description": "Items per page (max 100)" },
          { "name": "search", "in": "query", "schema": { "type": "string", "maxLength": 200 }, "description": "Search in name and description (max 200 chars)" },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["draft", "coming_soon", "published", "cancelled", "completed"] }, "description": "Filter by status (admin only; ignored for public)" },
          { "name": "sort_by", "in": "query", "schema": { "type": "string", "enum": ["created_at", "name", "remaining_spots"], "default": "created_at" }, "description": "Sort field" },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"], "default": "desc" }, "description": "Sort order" }
        ],
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Event" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                },
                "example": {
                  "success": true,
                  "data": [
                    {
                      "id": 1,
                      "name": "Summer Concert 2025",
                      "description": "Annual summer concert",
                      "capacity": 100,
                      "booked_count": 25,
                      "remaining_spots": 75,
                      "status": "published",
                      "created_at": "2025-03-01T10:00:00.000Z"
                    }
                  ],
                  "pagination": {
                    "page": 1,
                    "limit": 10,
                    "total": 1,
                    "total_pages": 1,
                    "has_next": false,
                    "has_prev": false
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Eventix API / Events"],
        "summary": "Create Event",
        "description": "Create a new event. **Admin only.** Default status is `draft`. Name 1–255 chars; description optional, max 2000 chars; capacity must be ≥ 1. Event is created with booked_count=0.",
        "operationId": "createEvent",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "capacity"],
                "properties": {
                  "name": { "type": "string", "maxLength": 255, "example": "Summer Concert 2025" },
                  "description": { "type": "string", "nullable": true, "maxLength": 2000, "example": "Annual summer concert at the park" },
                  "capacity": { "type": "integer", "minimum": 1, "example": 100 },
                  "status": { "type": "string", "enum": ["draft", "coming_soon", "published", "cancelled", "completed"], "default": "draft" }
                }
              },
              "example": {
                "name": "Summer Concert 2025",
                "description": "Annual summer concert at the park",
                "capacity": 100,
                "status": "draft"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Event created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": { "$ref": "#/components/schemas/Event" }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation failed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Authentication required", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/events/{eventId}": {
      "get": {
        "tags": ["Eventix API / Events"],
        "summary": "Get Event by ID",
        "description": "Get a single event by ID. **Public:** returns only `published` and `coming_soon` (404 for draft/cancelled/completed). **Admin (Bearer):** returns any status. Includes optional `max_tickets_per_booking` when per-event config exists.",
        "operationId": "getEventById",
        "parameters": [
          { "name": "eventId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Event details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": { "$ref": "#/components/schemas/Event" }
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid event ID", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": {
            "description": "Event not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "error": { "code": "EVB404001", "message": "Event not found", "details": { "event_id": 999 } }
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Eventix API / Events"],
        "summary": "Update Event",
        "description": "Update an event. **Admin only.** All fields optional (partial update). New capacity must be ≥ current `booked_count`. Cannot reduce capacity below booked tickets.",
        "operationId": "updateEvent",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "eventId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "maxLength": 255 },
                  "description": { "type": "string", "nullable": true },
                  "capacity": { "type": "integer", "minimum": 1 },
                  "status": { "type": "string", "enum": ["draft", "coming_soon", "published", "cancelled", "completed"] }
                }
              },
              "example": {
                "name": "Summer Concert 2025 (Updated)",
                "description": "Updated description",
                "capacity": 120,
                "status": "published"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": { "$ref": "#/components/schemas/Event" }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation failed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Authentication required", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Event not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/events/{eventId}/bookings": {
      "post": {
        "tags": ["Eventix API / Bookings"],
        "summary": "Book Tickets",
        "description": "Book tickets for a **published** event. **Auth required.** `ticket_count` (1–100) is validated against per-event config: **max_tickets_per_booking** (max per single request; default 6) and **max_tickets_per_user** (total across all bookings for this event; default 15). Per-event overrides in `event_booking_config`. Fails if sold out, not enough spots, or limits exceeded.",
        "operationId": "bookSpot",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "eventId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ticket_count": { "type": "integer", "minimum": 1, "maximum": 100, "default": 1, "description": "Number of tickets to book (1-100, subject to event config)" }
                },
                "example": { "ticket_count": 2 }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Booking created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": { "$ref": "#/components/schemas/Booking" }
                  }
                },
                "example": {
                  "success": true,
                  "data": {
                    "id": 1,
                    "event_id": 1,
                    "user_id": 1,
                    "ticket_count": 2,
                    "status": "confirmed",
                    "created_at": "2025-03-06T10:00:00.000Z",
                    "updated_at": "2025-03-06T10:00:00.000Z"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed (invalid event ID or ticket_count)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "success": false, "error": { "code": "EVB400001", "message": "Validation failed", "details": { "ticket_count": "Number must be less than or equal to 100" } } }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "success": false, "error": { "code": "EVB401001", "message": "Authentication required", "details": null } }
              }
            }
          },
          "404": {
            "description": "Event not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "success": false, "error": { "code": "EVB404001", "message": "Event not found", "details": { "event_id": 999 } } }
              }
            }
          },
          "409": {
            "description": "Event sold out, not enough spots, or booking limit exceeded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "soldOut": {
                    "summary": "Sold out",
                    "value": { "success": false, "error": { "code": "EVB409001", "message": "This event is sold out", "details": { "event_id": 1 } } }
                  },
                  "notEnoughSpots": {
                    "summary": "Not enough spots",
                    "value": { "success": false, "error": { "code": "EVB409001", "message": "Not enough spots available", "details": { "event_id": 1, "requested": 5, "remaining": 2 } } }
                  },
                  "limitExceeded": {
                    "summary": "Per-user limit exceeded",
                    "value": { "success": false, "error": { "code": "EVB409003", "message": "You can book at most 15 tickets for this event (you have 12)", "details": { "max_tickets_per_user": 15, "current": 12 } } }
                  },
                  "perBookingLimit": {
                    "summary": "Per-booking limit exceeded",
                    "value": { "success": false, "error": { "code": "EVB409003", "message": "Cannot book more than 6 tickets per booking", "details": { "max_tickets_per_booking": 6 } } }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "success": false, "error": { "code": "EVB429001", "message": "Too many requests", "details": null } }
              }
            }
          }
        }
      }
    },
    "/api/v1/bookings": {
      "get": {
        "tags": ["Eventix API / Bookings"],
        "summary": "List Bookings",
        "description": "List bookings with pagination. **User:** own bookings only. **Admin:** all users' bookings. Returns confirmed and cancelled.",
        "operationId": "listBookings",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 1 }, "description": "Page number" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 10 }, "description": "Items per page (max 100)" }
        ],
        "responses": {
          "200": {
            "description": "List of bookings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Booking" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                }
              }
            }
          },
          "401": { "description": "Authentication required", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/bookings/{bookingId}": {
      "get": {
        "tags": ["Eventix API / Bookings"],
        "summary": "Get Booking by ID",
        "description": "Get a single booking by ID. **User:** own bookings only (403 for others). **Admin:** any booking.",
        "operationId": "getBookingById",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "bookingId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Booking details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": { "$ref": "#/components/schemas/Booking" }
                  }
                }
              }
            }
          },
          "401": { "description": "Authentication required", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "success": false, "error": { "code": "EVB403001", "message": "You do not have permission to perform this action", "details": null } }
              }
            }
          },
          "404": {
            "description": "Booking not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "success": false, "error": { "code": "EVB404001", "message": "Booking not found", "details": { "booking_id": 999 } } }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Eventix API / Bookings"],
        "summary": "Cancel Booking",
        "description": "Cancel a confirmed booking. **User:** own only. **Admin:** any. Body optional: `{}` or `{ status: 'cancelled' }`. Decrements event `booked_count`. Returns 422 if already cancelled.",
        "operationId": "cancelBooking",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "bookingId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string", "enum": ["cancelled"], "example": "cancelled" }
                }
              },
              "example": { "status": "cancelled" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Booking cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": { "$ref": "#/components/schemas/Booking" }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation failed (invalid body)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Authentication required", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Booking not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "422": {
            "description": "Booking already cancelled",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "success": false, "error": { "code": "EVB422001", "message": "Booking is already cancelled", "details": { "booking_id": 1 } } }
              }
            }
          }
        }
      }
    },
    "/api/v1/audit-log": {
      "get": {
        "tags": ["Eventix API / Audit Log"],
        "summary": "List Audit Log",
        "description": "List combined event and booking audit entries. **Admin only.** Tracks create/update/delete (events), book/cancel (bookings). Filter by resource type, event/booking ID, outcome, or date range.",
        "operationId": "listAuditLog",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 1 }, "description": "Page number" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 10 }, "description": "Items per page (max 100)" },
          { "name": "resource_type", "in": "query", "schema": { "type": "string", "enum": ["event", "booking"] }, "description": "Filter by resource type" },
          { "name": "event_id", "in": "query", "schema": { "type": "integer", "minimum": 1 }, "description": "Filter by event ID" },
          { "name": "booking_id", "in": "query", "schema": { "type": "integer", "minimum": 1 }, "description": "Filter by booking ID" },
          { "name": "outcome", "in": "query", "schema": { "type": "string", "enum": ["success", "failure"] }, "description": "Filter by outcome" },
          { "name": "date_from", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "Filter entries from this date (ISO 8601)" },
          { "name": "date_to", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "Filter entries until this date (ISO 8601)" }
        ],
        "responses": {
          "200": {
            "description": "List of audit log entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/AuditLogEntry" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                },
                "example": {
                  "success": true,
                  "data": [
                    {
                      "id": 1,
                      "resource_type": "booking",
                      "operation": "book",
                      "event_id": 1,
                      "booking_id": 1,
                      "user_id": 1,
                      "ticket_count": 2,
                      "outcome": "success",
                      "details": null,
                      "error_code": null,
                      "error_message": null,
                      "created_at": "2025-03-06T10:00:00.000Z"
                    }
                  ],
                  "pagination": { "page": 1, "limit": 10, "total": 1, "total_pages": 1, "has_next": false, "has_prev": false }
                }
              }
            }
          },
          "401": { "description": "Authentication required", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "success": false, "error": { "code": "EVB403001", "message": "You do not have permission to perform this action", "details": null } }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT access token from login or register. Header: Authorization: Bearer <token>"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "description": "Standard error response",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string", "example": "EVB400001", "description": "EVB-prefixed error code" },
              "message": { "type": "string", "example": "Validation failed" },
              "details": { "type": "object", "nullable": true, "description": "Field-level errors or context" }
            }
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "description": "Auth response from register, login, or refresh",
        "properties": {
          "user": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "email": { "type": "string" },
              "name": { "type": "string", "nullable": true },
              "role": { "type": "string", "enum": ["user", "admin"] }
            }
          },
          "access_token": { "type": "string", "description": "JWT for Authorization header" },
          "refresh_token": { "type": "string", "description": "Use for refresh or logout" },
          "expires_in": { "type": "integer", "description": "Access token expiry in seconds" }
        }
      },
      "Event": {
        "type": "object",
        "description": "Event entity",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string", "maxLength": 255 },
          "description": { "type": "string", "nullable": true, "maxLength": 2000 },
          "capacity": { "type": "integer", "minimum": 1 },
          "booked_count": { "type": "integer", "minimum": 0 },
          "remaining_spots": { "type": "integer", "description": "capacity - booked_count" },
          "status": { "type": "string", "enum": ["draft", "coming_soon", "published", "cancelled", "completed"] },
          "max_tickets_per_booking": { "type": "integer", "description": "Per-event override; present when configured" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Booking": {
        "type": "object",
        "description": "Booking entity",
        "properties": {
          "id": { "type": "integer" },
          "event_id": { "type": "integer" },
          "user_id": { "type": "integer" },
          "ticket_count": { "type": "integer", "minimum": 1, "description": "Number of tickets in this booking" },
          "status": { "type": "string", "enum": ["confirmed", "cancelled"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "EventBookingConfig": {
        "type": "object",
        "description": "Per-event or default config. max_tickets_per_booking = max per single request (prevents grabbing many at once); max_tickets_per_user = total tickets user can have for this event across all bookings.",
        "properties": {
          "max_tickets_per_booking": { "type": "integer", "description": "Max tickets per single POST request" },
          "max_tickets_per_user": { "type": "integer", "description": "Max total tickets user can have for this event" }
        }
      },
      "AuditLogEntry": {
        "type": "object",
        "description": "Combined event and booking audit log entry",
        "properties": {
          "id": { "type": "integer", "description": "Audit log entry ID" },
          "resource_type": { "type": "string", "enum": ["event", "booking"], "description": "event or booking" },
          "operation": { "type": "string", "enum": ["create", "update", "delete", "fetch", "book", "cancel"], "description": "Operation performed" },
          "event_id": { "type": "integer", "description": "Related event ID" },
          "booking_id": { "type": "integer", "nullable": true, "description": "Related booking ID (null for event ops)" },
          "user_id": { "type": "integer", "nullable": true, "description": "User who performed the action" },
          "ticket_count": { "type": "integer", "nullable": true, "description": "Tickets booked/cancelled (for book/cancel)" },
          "outcome": { "type": "string", "enum": ["success", "failure"] },
          "details": { "type": "object", "nullable": true, "description": "Additional context" },
          "error_code": { "type": "string", "nullable": true, "description": "Error code when outcome is failure" },
          "error_message": { "type": "string", "nullable": true, "description": "Error message when outcome is failure" },
          "created_at": { "type": "string", "format": "date-time", "description": "When the action occurred" }
        }
      },
      "Pagination": {
        "type": "object",
        "description": "Pagination metadata for list endpoints",
        "properties": {
          "page": { "type": "integer", "description": "Current page (1-based)" },
          "limit": { "type": "integer", "description": "Items per page" },
          "total": { "type": "integer", "description": "Total items" },
          "total_pages": { "type": "integer", "description": "Total pages" },
          "has_next": { "type": "boolean" },
          "has_prev": { "type": "boolean" }
        }
      }
    }
  }
}
