# App: dev | test | stg | prod
NODE_ENV=dev
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eventix
DB_USER=postgres
DB_PASSWORD=Htrb@134Postgres#134

# Connection pool size. Default 20. For production under high load, consider 50-100.
DB_POOL_MAX=20

# Rate limit: window in ms (60000 = 60 sec = 1 min), max requests per window
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=100

# JWT (required)
JWT_SECRET=your-secret-change-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d
