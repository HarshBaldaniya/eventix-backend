# ──────────────────────────────────────────────────────
#  Eventix Backend — Environment Configuration
#  Copy this file and rename for your environment:
#    cp .env.example .env.dev      (local development)
#    cp .env.example .env.test     (test environment)
# ──────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────
NODE_ENV=dev                  # dev | test | stg | prod
PORT=3000                     # API server port

# ─── PostgreSQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eventix
DB_USER=postgres
DB_PASSWORD=root
DB_POOL_MAX=20                # Connection pool size (prod: 50-100)
# DB_SSL=true                 # Uncomment for remote/production databases

# ─── Redis ────────────────────────────────────────────
#  Option 1: Separate host/port (for local Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

#  Option 2: Full URL (for managed Redis like Render/Upstash)
# REDIS_URL=redis://user:password@host:port

# ─── Rate Limiting ────────────────────────────────────
API_RATE_LIMIT_WINDOW_MS=60000       # 60 seconds window
API_RATE_LIMIT_MAX_REQUESTS=100      # Max 100 requests per window per IP

# ─── JWT Authentication ──────────────────────────────
JWT_SECRET=your-secret-change-in-production
JWT_ACCESS_EXPIRY=1h                 # Access token lifetime
JWT_REFRESH_EXPIRY=7d                # Refresh token lifetime

# ─── CORS ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://127.0.0.1:3001,http://127.0.0.1:3002
