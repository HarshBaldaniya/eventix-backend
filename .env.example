# App: dev | test | stg | prod
NODE_ENV=dev
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=backend_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=10

# Rate limit: window in ms (60000 = 60 sec = 1 min), max requests per window
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=100
