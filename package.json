{
  "name": "backend",
  "version": "1.0.0",
  "description": "Layered backend with Express, TypeScript, PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "cross-env NODE_ENV=dev ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "cross-env NODE_ENV=test ts-node-dev --respawn --transpile-only src/index.ts",
    "stg": "cross-env NODE_ENV=stg ts-node-dev --respawn --transpile-only src/index.ts",
    "prod": "cross-env NODE_ENV=prod node dist/index.js",
    "start:dev": "cross-env NODE_ENV=dev node dist/index.js",
    "start:test": "cross-env NODE_ENV=test node dist/index.js",
    "start:stg": "cross-env NODE_ENV=stg node dist/index.js",
    "start:prod": "cross-env NODE_ENV=prod node dist/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "pg": "^8.13.0",
    "winston": "^3.14.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.6",
    "cross-env": "^10.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
